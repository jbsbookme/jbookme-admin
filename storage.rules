rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // REGLA SIMPLIFICADA PARA DEPURACIÓN:
    // La regla original (abajo) hacía una llamada a Firestore que bloqueaba la subida.
    // Esta regla temporal solo comprueba que el usuario haya iniciado sesión.
    // Si la subida funciona con esta regla, el problema está confirmado.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    /*
    REGLA ORIGINAL QUE CAUSA EL PROBLEMA:

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
    */
  }
}
